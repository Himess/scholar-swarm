# Copy to .env (gitignored) and fill in real values.
# All keys listed here are consumed somewhere in the codebase.

# ---------- 0G Galileo Testnet ----------
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_GALILEO_EID=40428
OG_EXPLORER_URL=https://chainscan-galileo.0g.ai

# 0G Compute (Spike 1) — TEE-attested inference via @0glabs/0g-serving-broker
OG_COMPUTE_PROVIDER=0xa48f01287233509FD694a22Bf840225062E67836
OG_COMPUTE_MODEL=qwen-2.5-7b-instruct

# 0G Storage (Spike 5) — merkle-rooted blob/KV
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# ---------- Base Sepolia ----------
BASE_SEPOLIA_RPC=https://base-sepolia-rpc.publicnode.com
BASE_SEPOLIA_EID=40245
BASE_SEPOLIA_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ---------- Deployed contract addresses (0G Galileo) ----------
OG_AGENT_NFT=0x68c0175e9d9C6d39fC2278165C3Db93d484a5361
OG_REPUTATION_REGISTRY=0xE8D84bfD8756547BE86265cDE8CdBcd8cdfC8a13
OG_ARTIFACT_REGISTRY=0xB83e014c837763C4c86f21C194d7Fb613edFbE2b
OG_BOUNTY_FACTORY=0xdcCcce054BA878ecbe7dC540F9370040BEd7629d
OG_BOUNTY_IMPL=0xf36fEA634e48B67968567e04e75cd6b2A2698DAE
OG_BOUNTY_FACTORY_V1=0x3fC3BA7e2700449Cde5F06a8DF6f5FA1E18201BE
OG_BOUNTY_IMPL_V1=0x3905554071E2F121533EbB26Fcf7947C916299C1
OG_BOUNTY_MESSENGER=0x55b4bccdef026c8cbf5ab495a85aa28f235a4fed

# ---------- Deployed contract addresses (Base Sepolia) ----------
BASE_PAYMENT_ROUTER=0xda6ab98bb73e75b2581b72c98f0891529eee2156
BASE_PAYMENT_MESSENGER=0x1a4aad2bc39934fa0256e279b8a9377d708a8cd4

# ---------- Gensyn AXL ----------
# Single-host catch-all — used by spike-02a / spike-03 / spike-20 (axl-node-a/b)
AXL_NODE_LISTEN_ADDR=/ip4/0.0.0.0/tcp/4001
AXL_BOOTSTRAP_PEERS=
AXL_PEER_ID=
AXL_NODE_NAME=

# Per-agent peer IDs for spike-18 multi-process choreography
# (read by axl-client/messaging.ts staticPeers list — fill after `node.exe` first run logs each)
AXL_PEER_ID_PLANNER=
AXL_PEER_ID_RESEARCHER_1=
AXL_PEER_ID_RESEARCHER_2=
AXL_PEER_ID_CRITIC=
AXL_PEER_ID_SYNTHESIZER=

# ---------- KeeperHub ----------
KEEPERHUB_ENDPOINT=https://app.keeperhub.com
KEEPERHUB_API_KEY=
KEEPERHUB_ACCOUNT_ID=
# KH Para wallet — whitelisted as keeper on PaymentRouter; we never hold its key
KEEPERHUB_WALLET_ADDR=0x7109C8e3B56C0A94729F3f538105b6916EF5934B
# Workflow id created in Spike 14 — listens for DistributeRequested, signs PaymentRouter.distribute()
KEEPERHUB_WORKFLOW_ID=nepsavmovlyko0luy3rpi
KEEPERHUB_WORKFLOW_KEY=

# ---------- Retrieval (MCP / RetrievalProvider) ----------
# Default: SearXNG (self-hosted, zero-vendor) reachable via SSH tunnel from the VPS.
RETRIEVAL_PROVIDER=searxng
SEARXNG_ENDPOINT=http://127.0.0.1:8888
# Alternative: Tavily MCP (set TAVILY_API_KEY and flip RETRIEVAL_PROVIDER=tavily)
TAVILY_API_KEY=

# ---------- Wallets (DEMO ONLY — testnet keys, never real funds) ----------
# Deployer / user wallet
DEMO_USER_KEY=
DEMO_PLANNER_KEY=

# Per-agent operator wallets (Spike 18 minted iNFTs to 5 distinct EOAs)
PLANNER_OPERATOR_KEY=
PLANNER_OPERATOR_WALLET=
RESEARCHER_1_OPERATOR_KEY=
RESEARCHER_1_OPERATOR_WALLET=
RESEARCHER_2_OPERATOR_KEY=
RESEARCHER_2_OPERATOR_WALLET=
CRITIC_OPERATOR_KEY=
CRITIC_OPERATOR_WALLET=
SYNTHESIZER_OPERATOR_KEY=
SYNTHESIZER_OPERATOR_WALLET=

# Agent IDs (filled after `pnpm mint:agents`)
PLANNER_AGENT_ID=
RESEARCHER_1_AGENT_ID=
RESEARCHER_2_AGENT_ID=
CRITIC_AGENT_ID=
SYNTHESIZER_AGENT_ID=

# ---------- Runtime ----------
LOG_LEVEL=info
NODE_ENV=development
# Bid window for the multi-process planner (Spike 18) — 120s recommended on testnet
BID_WINDOW_MS=120000

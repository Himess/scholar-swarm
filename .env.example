# Copy to .env (gitignored) and fill in real values.
# All keys listed here are consumed somewhere in the codebase.

# ---------- 0G Labs ----------
# Testnet RPC endpoint (verify via Spike 1)
OG_RPC_URL=
OG_CHAIN_ID=
OG_EXPLORER_URL=
OG_EXPLORER_KEY=

# 0G Compute — API credentials + preferred model (filled after Spike 1)
OG_COMPUTE_ENDPOINT=
OG_COMPUTE_API_KEY=
OG_COMPUTE_MODEL_RESEARCHER=
OG_COMPUTE_MODEL_CRITIC=

# 0G Storage
OG_STORAGE_ENDPOINT=
OG_STORAGE_API_KEY=

# ---------- Gensyn AXL ----------
AXL_NODE_LISTEN_ADDR=/ip4/0.0.0.0/tcp/4001
AXL_BOOTSTRAP_PEERS=
AXL_PEER_ID=
# Set per-agent to distinguish identities when running multiple on one host
AXL_NODE_NAME=

# ---------- KeeperHub ----------
KEEPERHUB_ENDPOINT=
KEEPERHUB_API_KEY=
KEEPERHUB_ACCOUNT_ID=

# ---------- Retrieval (MCP) ----------
TAVILY_API_KEY=

# ---------- Wallets (DEMO ONLY — never real funds) ----------
DEMO_USER_KEY=
DEMO_PLANNER_KEY=
DEMO_RESEARCHER_1_KEY=
DEMO_RESEARCHER_2_KEY=
DEMO_CRITIC_KEY=
DEMO_SYNTHESIZER_KEY=

# ---------- Runtime ----------
LOG_LEVEL=info
NODE_ENV=development
